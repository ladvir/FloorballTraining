{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "wait-for-api",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-NonInteractive",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/wait-for-api.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "group": "startup"
            }
        },
        {
            "label": "build-api",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/FloorballTraining.API/FloorballTraining.API.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
