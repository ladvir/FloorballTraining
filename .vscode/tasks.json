{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "wait-for-api",
            "type": "shell",
            "options": {
                "shell": {
                    "executable": "powershell",
                    "args": ["-NoProfile", "-NonInteractive", "-Command"]
                }
            },
            "command": "$port = 5210; $max = 60; $i = 0; Write-Host \"Cekam na API (port $port)...\"; while ($i -lt $max) { try { $t = [System.Net.Sockets.TcpClient]::new(); $t.Connect('localhost', $port); $t.Close(); Write-Host 'API je pripravene.'; exit 0 } catch { Start-Sleep -Seconds 1; $i++ } }; Write-Host 'Timeout - API nespusteno'; exit 1",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "group": "startup"
            }
        },
        {
            "label": "build-api",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/FloorballTraining.API/FloorballTraining.API.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
