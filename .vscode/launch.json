{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FloorballTraining.API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/FloorballTraining.API/bin/Debug/net9.0/FloorballTraining.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/FloorballTraining.API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5210"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "FloTr: npm dev",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/FloTr",
            "preLaunchTask": "wait-for-api",
            "serverReadyAction": {
                "pattern": "Local:\\s+(https?://localhost:\\d+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Launch Chrome against localhost",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/FloTr/src"
        },
        {
            "name": "Playwright: run & show report",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx playwright test; npx playwright show-report",
            "cwd": "${workspaceFolder}/FloTr",
            "preLaunchTask": "wait-for-api"
        },
        {
            "name": "Playwright E2E: Headless",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx playwright test",
            "cwd": "${workspaceFolder}/FloTr"
        },
        {
            "name": "Playwright E2E: Headed (browser visible)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx playwright test --headed",
            "cwd": "${workspaceFolder}/FloTr"
        },
        {
            "name": "Playwright E2E: UI mode (interactive)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx playwright test --ui",
            "cwd": "${workspaceFolder}/FloTr"
        }
    ],
    "compounds": [
        {
            "name": "UI tests",
            "configurations": [
                "FloorballTraining.API",
                "Playwright: run & show report"
            ],
            "stopAll": true
        },
        {
            "name": "Run npm run dev",
            "configurations": [
                "FloorballTraining.API",
                "FloTr: npm dev"
            ],
            "stopAll": true
        }
    ]
}