{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Enrichers.Environment", "Serilog.Enrichers.Thread" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.json",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Login": { "PermitLimit": 5, "WindowMinutes": 15 },
    "ForgotPassword": { "PermitLimit": 3, "WindowMinutes": 60 },
    "Register": { "PermitLimit": 3, "WindowMinutes": 60 }
  },
  "AuditLog": {
    "RetentionDays": 730
  },
  "ALLOWED_ORIGINS": [],
  "FileUpload": {
    "MaxBytes": 10485760
  },
  "ConnectionStrings": {
    "FloorballTraining": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=FloorballTraining;Integrated Security=True;TrustServerCertificate=true",
    "FloorballTrainingAPIContext": "Server=(localdb)\\mssqllocaldb;Database=FloorballTrainingAPIContext-aa0c1224-72b2-4bb1-8603-c3ed2269dc89;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "FrontendBaseUrl": "http://localhost:3000",
  "CacheSettings": {
    "ReferenceDataTtlMinutes": 15
  },
  "JwtSettings": {
    "SecretKey": "FloTr-Super-Secret-Key-Must-Be-At-Least-64-Characters-Long-For-HMAC-SHA512",
    "Issuer": "FloTr",
    "Audience": "FloTr",
    "TokenExpirationMinutes": "60",
    "AccessTokenExpirationMinutes": "15",
    "RefreshTokenExpirationDays": "7"
  }
}